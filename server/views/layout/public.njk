{% extends "govuk/template.njk" %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set assetPath = '/assets/rebrand' %}
{% set govukRebrand = true %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet" />
  <meta name="google-site-verification" content="ThvYU2V6sfjD-kyyj2zaZ8lZUxn-8qnsoiQCaFZHccQ" />
{% endblock %}

{% block pageTitle %}
  {{ (applicationName + " - " + pageTitle) | default(applicationName) }}
{% endblock %}

{% block headIcons %}
  <link rel="shortcut icon" sizes="16x16 32x32 48x48" href="/assets/images/favicon.ico" type="image/x-icon" />
  <link rel="icon" sizes="any" href="/assets/images/favicon.svg" type="image/svg+xml">
{% endblock %}

{% block skipLink %}
  {{ super() }}
  {% if not cookieAccepted %}
    {% include "partials/cookie-banner.njk" %}
  {% endif %}
{% endblock %}

{% block header %}
  {% include "partials/header.njk" %}
  {{ govukPhaseBanner({
    tag: {
      text: "Beta"
    },
    html: 'This is a new service. <a href="/about-the-service" class="govuk-link" id="about-the-service">Find out more and help us improve it</a>.'
  }) }}

  {% if backLink %}
    <div class="govuk-width-container">
      {{ govukBackLink({
        text: "Back",
        href: backLink
      }) }}
    </div>
  {% endif %}

  {% block mainContent %}
  {% endblock %}

{% endblock %}

{% block content %}
{% endblock %}

{% block bodyStart %}
  {% include "partials/google-tag-manager-noscript.njk" %}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}" nonce="{{ cspNonce }}"></script>
{% endblock %}

{% block footer %}
{% include "partials/footer.njk" %}
{% endblock %}
