{% extends "layout/citizen-authenticated.njk" %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/password-input/macro.njk" import govukPasswordInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% set passwordError = (errorList or []) | selectattr("href", "equalto", "#password") | first %}

{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  <div class="govuk-grid-row govuk-!-margin-bottom-6">
    <div class="govuk-grid-column-two-thirds">
      {% if errorList %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errorList
        }) }}
      {% endif %}

      <form method="post" action="{{ privateBetaSignInApi }}" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

          <div class="govuk-form-group {{ 'govuk-form-group--error' if passwordError }}">
               <h1 class="govuk-label-wrapper">
                 <label class="govuk-label govuk-label--l" for="password">
                   Enter your {{ applicationName }} password
                 </label>
               </h1>

               <p class="govuk-body">
                  This service is currently in private beta. To use {{ applicationName }}, you need the password from your sign-up confirmation email.
               </p>

               <p class="govuk-hint">
                 You can find this on your sign-up confirmation email
               </p>

               {{ govukPasswordInput({
                 classes: "govuk-input--width-20",
                 id: "password",
                 name: "password",
                 type: "password",
                 autocomplete: "current-password",
                 errorMessage: passwordError
               }) }}
             </div>

        {{ govukButton({
          text: "Sign in"
        }) }}
      </form>
      <details class="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">I don't have a sign-up confirmation email</span>
        </summary>
        <div class="govuk-details__text">
          Contact your police witness care officer, who will give you access if it’s appropriate for your individual case.
        </div>
      </details>
    </div>
  </div>
{% endblock %}
