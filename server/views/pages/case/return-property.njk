{% extends "layout/citizen-authenticated.njk" %}

{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  <div class="govuk-grid-row govuk-!-margin-bottom-6">
    <div class="govuk-grid-column-two-thirds">
      <div class="gem-c-heading govuk-!-margin-bottom-8">
        <h1 class="gem-c-heading__text govuk-heading-xl">
          Understand your rights
        </h1>
      </div>
      <aside class="part-navigation-container" role="complementary">
        <nav data-module="ga4-link-tracker" aria-label="Pages in this guide" class="gem-c-contents-list govuk-!-margin-bottom-4" data-ga4-link-tracker-module-started="true">
          <h2 class="gem-c-contents-list__title">
            Contents
          </h2>
          <ol class="gem-c-contents-list__list">
            <li class="gem-c-contents-list__list-item gem-c-contents-list__list-item--dashed">
              <span class="gem-c-contents-list__list-item-dash" aria-hidden="true"></span>
              <a class="gem-c-contents-list__link govuk-link gem-c-force-print-link-styles" href="/case/victim-personal-statement">Giving a Victim Personal Statement</a>
            </li>
            <li class="gem-c-contents-list__list-item gem-c-contents-list__list-item--dashed">
              <span class="gem-c-contents-list__list-item-dash" aria-hidden="true"></span>
              <a class="gem-c-contents-list__link govuk-link gem-c-force-print-link-styles" href="/case/understand-compensation">When you can claim compensation</a>
            </li>
            <li class="gem-c-contents-list__list-item gem-c-contents-list__list-item--dashed gem-c-contents-list__list-item--active" aria-current="true">
              <span class="gem-c-contents-list__list-item-dash" aria-hidden="true"></span>
              Getting your property back
            </li>
            <li class="gem-c-contents-list__list-item gem-c-contents-list__list-item--dashed">
              <span class="gem-c-contents-list__list-item-dash" aria-hidden="true"></span>
              <a class="gem-c-contents-list__link govuk-link gem-c-force-print-link-styles" href="/case/victims-code">Victims' Code</a>
            </li>
          </ol>
        </nav>
      </aside>
    </div>
  </div>
  <div class="govuk-grid-row govuk-!-margin-bottom-6">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Getting your property back</h2>
      <p class="govuk-body">When you experience a crime, the police might have to take things that belong to you to help them with the investigation. Some things might also be used as evidence in the court trial.</p>
      <p class="govuk-body">You are usually able to have your property back when the case ends and there’s no appeal. You do not have to take it back.</p>

      <h3 class="govuk-heading-m">How to get your property back</h3>
      <p class="govuk-body">When the case ends, you can ask the police officer in charge of your case for your property back.</p>
      <p class="govuk-body">They will ask you to come to your local police station to collect your property. You will need to bring personal ID, for example your driving licence or passport.</p>

      <h3 class="govuk-heading-m">Contact the police officer in charge</h3>
      <p class="govuk-body">If you do not have the contact details of your police officer in charge or local police force, contact the police by phone or online.</p>
      <p class="govuk-body">Telephone: 101<br><a href="https://www.police.uk/pu/contact-us/updates/" class="govuk-link" target="_blank">Contact the police online (opens in new tab)</a>.</p>
    </div>
  </div>
{% endblock %}