{% extends "layout/citizen-authenticated.njk" %}

{% from "components/action-card/macro.njk" import actionCard %}

{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  <h1 class="govuk-heading-xl govuk-!-static-margin-bottom-8">{{ applicationName }}</h1>
  <div class="govuk-grid-row govuk-!-margin-bottom-6">
    <div class="govuk-grid-column-one-third">
      {{ actionCard(
        "Find your court information",
        "Look up the court where the next hearing or trial for your case is being held. You need your unique reference number.",
        "/case/search",
        "Find your court"
      ) }}
    </div>
    <div class="govuk-grid-column-one-third">
      {{ actionCard(
        "The criminal justice system: step by step",
        "See what stage you’re at and understand what happens next.",
        "/case/victims-journey",
        "Find out about the process"
      ) }}
    </div>
    <div class="govuk-grid-column-one-third">
      {{ actionCard(
        "Who does what in the criminal justice system",
        "Learn about the people involved, including who will help you when you experience a crime.",
        "/case/key-roles",
        "Find out who's who"
      ) }}
    </div>
  </div>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
      {{ actionCard(
        "Understand your rights",
        "Including making a victim personal statement, compensation, and your property.",
        "/case/victim-personal-statement",
        "Find out about your rights"
      ) }}
    </div>
    <div class="govuk-grid-column-one-third">
      {{ actionCard(
        "Find help and support",
        "Find charities and organisations that can give you further support and advice.",
        "/case/victim-support-links",
        "Find support"
      ) }}
    </div>
    <div class="govuk-grid-column-one-third">
      <div class="govuk-summary-card highlight">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title text-white">If you need help now</h2>
        </div>
        <div class="govuk-summary-card__content">
          <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
              <p class="govuk-body text-white">If you're in immediate danger, phone the police: 999</p>
              <p class="govuk-body">
                <span class="text-white">Samaritans phone: 116 123</span><br>
                <span class="text-white">Website: </span><a href="https://www.samaritans.org" class="govuk-link govuk-link--inverse" target="_blank">www.samaritans.org (opens in new tab)</a>
              </p>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>

{% endblock %}
