{% extends "layout/citizen-authenticated.njk" %}

{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l" title="{{ message }}">Court information</h1>
      <div class="govuk-notification-banner govuk-!-margin-bottom-6" role="alert" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">Important</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <h3 class="govuk-notification-banner__heading">Sorry, there is a problem with the court information service</h3>
          <p class="govuk-body">Try again later.</p>
          <p class="govuk-body">If you need information about a court, use the <a href="https://www.find-court-tribunal.service.gov.uk/" class="govuk-link" target="_blank">Find a court or tribunal service (opens in new tab)</a>.</p>
          <p class="govuk-body">If you need an update on your case, you can contact the police. Find their contact details on any letter they have sent you, or <a href="https://www.police.uk/pu/find-a-police-force/" class="govuk-link" target="_blank">find your local police force (opens in new tab)</a>.</p>
        </div>
      </div>

      {% include "pages/case/court-information-generic-summary.njk" %}

    </div>
  </div>

{% endblock %}
